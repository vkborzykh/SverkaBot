# SverkaBot — environment variables example
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated list of Telegram user IDs who are admins
TELEGRAM_ADMIN_IDS=

# ── Internal API security ─────────────────────────────────────────────────────
# Used for bot → backend calls (X-Internal-Token header)
INTERNAL_TOKEN=
# Used for admin API calls (Bearer token)
ADMIN_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase transaction pooler (port 6543) — for app queries
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Supabase direct connection (port 5432) — for drizzle-kit migrations
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase JS client ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Payment provider ──────────────────────────────────────────────────────────
PAYMENT_PROVIDER_SECRET=

# ── Public URL ────────────────────────────────────────────────────────────────
# Base URL used for generating payment links and callbacks
PUBLIC_URL=http://localhost:3000
