# SverkaBot — environment variables example
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated list of Telegram user IDs who are admins
TELEGRAM_ADMIN_IDS=

# ── Internal API security ─────────────────────────────────────────────────────
# Used for bot → backend calls (X-Internal-Token header)
INTERNAL_TOKEN=
# Used for admin API calls (Bearer token)
ADMIN_TOKEN=
# Used by Vercel Cron: Vercel sends `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase transaction pooler (port 6543) — for app queries
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Supabase direct connection (port 5432) — for drizzle-kit migrations
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase JS client ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=sverkabot

# ── Payment provider ──────────────────────────────────────────────────────────
PAYMENT_PROVIDER_SECRET=

# ── Public URL ────────────────────────────────────────────────────────────────
PUBLIC_URL=http://localhost:3000

# ── Queue driver (Phase 1) ────────────────────────────────────────────────────
# 'db'   = legacy: Vercel cron drains the jobs table in-process (rollback path)
# 'bull' = production: always-on worker drains jobs → BullMQ on the backend host
# Set 'bull' on BOTH Vercel and the worker after cutover; 'db' to roll back.
QUEUE_DRIVER=db

# ── Redis / BullMQ (worker host only) ─────────────────────────────────────────
# Local Redis on the same VM (no TLS). For a managed rediss:// endpoint,
# ioredis enables TLS automatically from the URL scheme.
REDIS_URL=redis://127.0.0.1:6379

# ── Worker tuning (worker host only) ──────────────────────────────────────────
WORKER_CONCURRENCY=3
WORKER_HEALTH_PORT=8080
POLL_INTERVAL_MS=3000
POLL_BATCH=50
STUCK_JOB_MINUTES=10
